{
    "name": "itss/project-management",
    "description": "ITSS Project Management System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "ITSS\\": "src/"
